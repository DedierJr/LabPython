        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import matplotlib.cm as cm\n",
        "import unicodedata\n",
        "from geobr import read_municipality\n",
        "\n",
        "# ==============================================================================\n",
        "# 0. CONFIGURAÇÕES GERAIS E FUNÇÕES UTILITÁRIAS\n",
        "# ==============================================================================\n",
        "\n",
        "MUNICIPIOS_SUL = [\n",
        "    'Aceguá', 'Arroio Grande', 'Arroio do Padre', 'Candiota', 'Canguçu',\n",
        "    'Capão do Leão', 'Cerrito', 'Chuí', 'Herval', 'Jaguarão',\n",
        "    'Morro Redondo', 'Pedras Altas', 'Pedro Osório', 'Pelotas',\n",
        "    'Pinheiro Machado', 'Piratini', 'Rio Grande', 'Santa Vitória do Palmar',\n",
        "    'São José do Norte', 'São Lourenço do Sul', 'Santana da Boa Vista', 'Turuçu'\n",
        "]\n",
        "\n",
        "MUNICIPIOS_ESPECIAIS = ['Piratini', 'Santana da Boa Vista', 'Pedras Altas']\n",
        "\n",
        "def normalizar_nome(texto):\n",
        "    \"\"\"Remove acentos, espaços extras e converte para minúsculas.\"\"\"\n",
        "    if not isinstance(texto, str):\n",
        "        return \"\"\n",
        "    texto_limpo = unicodedata.normalize('NFKD', texto).encode('ascii', 'ignore').decode('utf-8')\n",
        "    return texto_limpo.lower().strip()\n",
        "\n",
        "# ==============================================================================\n",
        "# 1. CARREGAMENTO E TRATAMENTO DE DADOS\n",
        "# ==============================================================================\n",
        "\n",
        "urls = {\n",
        "    'frota': \"https://raw.githubusercontent.com/DedierJr/LabPython/refs/heads/main/frotaRS.csv\",\n",
        "    'pibpc': \"https://raw.githubusercontent.com/DedierJr/LabPython/refs/heads/main/pibpc_municipios_rs.csv\",\n",
        "    'populacao': \"https://raw.githubusercontent.com/DedierJr/LabPython/refs/heads/main/populacaoRS.csv\"\n",
        "}\n",
        "\n",
        "print(\"Carregando dados...\")\n",
        "dfs = {}\n",
        "\n",
        "try:\n",
        "    for chave, url in urls.items():\n",
        "        df = pd.read_csv(url, thousands='.', decimal=',')\n",
        "        df.columns = ['ano', 'municipio', chave]\n",
        "        df[chave] = pd.to_numeric(df[chave], errors='coerce')\n",
        "        dfs[chave] = df\n",
        "except Exception as e:\n",
        "    print(f\"Erro ao carregar os dados: {e}\")\n",
        "    exit()\n",
        "\n",
        "print(\"\\n=== DIAGNÓSTICO E LIMPEZA DE DUPLICATAS ===\")\n",
        "for chave, df in dfs.items():\n",
        "    total_inicial = len(df)\n",
        "    duplicatas = df[df.duplicated(subset=['ano', 'municipio'], keep=False)]\n",
        "    print(f\"{chave.capitalize()} - Total: {total_inicial} | Duplicados: {len(duplicatas)}\")\n",
        "\n",
        "    # Remove duplicatas\n",
        "    dfs[chave] = df.drop_duplicates(subset=['ano', 'municipio'], keep='first')\n",
        "    print(f\"{chave.capitalize()} após limpeza: {len(dfs[chave])} registros\\n\")\n",
        "\n",
        "# --- UNIFICAÇÃO DAS TABELAS (MERGE) ---\n",
        "df_completo = pd.merge(dfs['frota'], dfs['pibpc'], on=['ano', 'municipio'], how='inner')\n",
        "df_completo = pd.merge(df_completo, dfs['populacao'], on=['ano', 'municipio'], how='inner').dropna()\n",
        "\n",
        "print(f\"DataFrame completo após merge: {len(df_completo)} registros\")\n",
        "\n",
        "# --- PREPARAÇÃO DOS DATASETS ESPECÍFICOS ---\n",
        "\n",
        "# 1. Dataset Rio Grande\n",
        "df_rg = df_completo[df_completo['municipio'] == 'Rio Grande'].sort_values('ano').copy()\n",
        "\n",
        "# 2. Dataset Região Sul (Agregação com PIB Ponderado)\n",
        "df_sul_temp = df_completo[df_completo['municipio'].isin(MUNICIPIOS_SUL)].copy()\n",
        "df_sul_temp['pib_total_absoluto_sul'] = df_sul_temp['pibpc'] * df_sul_temp['populacao']\n",
        "\n",
        "df_sul = df_sul_temp.groupby('ano').agg({\n",
        "    'frota': 'sum',\n",
        "    'populacao': 'sum',\n",
        "    'pib_total_absoluto_sul': 'sum'\n",
        "}).reset_index()\n",
        "\n",
        "df_sul['pibpc'] = df_sul['pib_total_absoluto_sul'] / df_sul['populacao']\n",
        "df_sul = df_sul[['ano', 'frota', 'pibpc', 'populacao']].sort_values('ano').copy()\n",
        "\n",
        "# 3. Dataset Média RS (Agregação Estadual Ponderada)\n",
        "df_completo['pib_total_absoluto'] = df_completo['pibpc'] * df_completo['populacao']\n",
        "\n",
        "rs_grouped = df_completo.groupby('ano').agg({\n",
        "    'frota': 'sum',\n",
        "    'populacao': 'sum',\n",
        "    'pib_total_absoluto': 'sum'\n",
        "}).reset_index()\n",
        "\n",
        "rs_grouped['pibpc'] = rs_grouped['pib_total_absoluto'] / rs_grouped['populacao']\n",
        "df_rs = rs_grouped[['ano', 'frota', 'pibpc', 'populacao']].copy()\n",
        "\n",
        "analises = {\n",
        "    'Rio Grande': df_rg,\n",
        "    'Região Sul (22 municípios)': df_sul,\n",
        "    'Média RS (Ponderada)': df_rs\n",
        "}\n",
        "\n",
        "print(f\"\\nBase completa carregada com {len(df_completo)} registros processados.\")\n",
        "print(\"-\" * 90)\n",
        "\n",
        "# ==============================================================================\n",
        "# 2. CÁLCULO DAS ESTATÍSTICAS COMPARATIVAS\n",
        "# ==============================================================================\n",
        "print(\"\\n>>> ANÁLISE 1: ESTATÍSTICAS COMPARATIVAS DE CRESCIMENTO\")\n",
        "\n",
        "stats_list = []\n",
        "print(f\"{'LOCAL':<25} | {'GANHO REAL (R$)':<20} | {'CRESCIMENTO PIB %':<20} | {'RETORNO (Veic/R$1k)'}\")\n",
        "print(\"-\" * 100)\n",
        "\n",
        "for local, df in analises.items():\n",
        "    if df.empty: continue\n",
        "\n",
        "    ano_ini, ano_fim = df.iloc[0], df.iloc[-1]\n",
        "\n",
        "    ganho_real = ano_fim['pibpc'] - ano_ini['pibpc']\n",
        "    crescimento_pib_pct = (ganho_real / ano_ini['pibpc']) * 100 if ano_ini['pibpc'] else 0\n",
        "\n",
        "    aumento_frota = ano_fim['frota'] - ano_ini['frota']\n",
        "    crescimento_frota_pct = (aumento_frota / ano_ini['frota']) * 100 if ano_ini['frota'] else 0\n",
        "\n",
        "    retorno_populacao = aumento_frota / (ganho_real / 1000) if ganho_real > 0 else 0\n",
        "\n",
        "    stats_list.append({\n",
        "        'Local': local, 'Ganho Real (R$)': ganho_real, 'Crescimento PIB (%)': crescimento_pib_pct,\n",
        "        'Aumento Frota Absoluto': aumento_frota, 'Crescimento Frota (%)': crescimento_frota_pct,\n",
        "        'Retorno (Veic/1k)': retorno_populacao\n",
        "    })\n",
        "\n",
        "    print(f\"{local:<25} | R$ {ganho_real:,.2f}          | {crescimento_pib_pct:.2f}%                | {retorno_populacao:.2f} veículos\")\n",
        "\n",
        "df_stats = pd.DataFrame(stats_list)\n",
        "\n",
        "# ==============================================================================\n",
        "# 2.1. ANÁLISE COMPLEMENTAR: COEFICIENTE DE VARIAÇÃO (CV) DA DESIGUALDADE\n",
        "# ==============================================================================\n",
        "print(\"\\n>>> CÁLCULO DO COEFICIENTE DE VARIAÇÃO (DISPARIDADE MUNICIPAL)\")\n",
        "\n",
        "def calcular_cv(dados):\n",
        "    cv_pib = (dados['pibpc'].std() / dados['pibpc'].mean()) * 100\n",
        "    cv_frota = (dados['frota'].std() / dados['frota'].mean()) * 100\n",
        "    return pd.Series({'CV_PIBpc (%)': cv_pib, 'CV_Frota (%)': cv_frota})\n",
        "\n",
        "df_cv_rs = df_completo.groupby('ano').apply(calcular_cv).reset_index()\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(df_cv_rs['ano'], df_cv_rs['CV_PIBpc (%)'], marker='o', linewidth=2, label='Desigualdade do PIB per capita', color='tab:blue')\n",
        "plt.plot(df_cv_rs['ano'], df_cv_rs['CV_Frota (%)'], marker='s', linewidth=2, linestyle='--', label='Desigualdade da Frota', color='tab:red')\n",
        "plt.title('Evolução da Disparidade entre os Municípios Gaúchos (CV%)', fontsize=12, fontweight='bold')\n",
        "plt.xlabel('Ano')\n",
        "plt.ylabel('Coeficiente de Variação (%)')\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig('evolucao_disparidade_cv.png', dpi=150)\n",
        "plt.show() # <-- ADICIONADO AQUI\n",
        "plt.close()\n",
        "print(\"✓ Gráfico de disparidade salvo e exibido.\")\n",
        "\n",
        "# ==============================================================================\n",
        "# 3. GRÁFICOS COMPARATIVOS GERAIS\n",
        "# ==============================================================================\n",
        "\n",
        "fig, ax = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "# Gráfico 1: Aumento Real\n",
        "barras1 = ax[0].bar(df_stats['Local'], df_stats['Ganho Real (R$)'], color=['#1f77b4', '#ff7f0e', 'green'], alpha=0.8)\n",
        "ax[0].set_title('Aumento Real da Renda (2010-2023)', fontsize=12, fontweight='bold')\n",
        "ax[0].set_ylabel('Aumento em R$ (PIB per Capita)')\n",
        "ax[0].grid(axis='y', linestyle='--', alpha=0.5)\n",
        "ax[0].tick_params(axis='x', rotation=15)\n",
        "\n",
        "for barra in barras1:\n",
        "    height = barra.get_height()\n",
        "    ax[0].text(barra.get_x() + barra.get_width()/2., height, f'R$ {height:,.0f}', ha='center', va='bottom')\n",
        "\n",
        "# Gráfico 2: Taxas de Crescimento\n",
        "x = np.arange(len(df_stats['Local']))\n",
        "width = 0.35\n",
        "\n",
        "ax[1].bar(x - width/2, df_stats['Crescimento PIB (%)'], width, label='Crescimento Renda (%)', color='navy')\n",
        "ax[1].bar(x + width/2, df_stats['Crescimento Frota (%)'], width, label='Crescimento Frota (%)', color='firebrick')\n",
        "ax[1].set_ylabel('Crescimento Percentual Total (%)')\n",
        "ax[1].set_title('Renda vs. Veículos: Comparativo %', fontsize=12, fontweight='bold')\n",
        "ax[1].set_xticks(x)\n",
        "ax[1].set_xticklabels(df_stats['Local'], rotation=15)\n",
        "ax[1].legend()\n",
        "ax[1].grid(axis='y', linestyle='--', alpha=0.5)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('a7.png', dpi=150, bbox_inches='tight')\n",
        "plt.show() # <-- ADICIONADO AQUI\n",
        "plt.close()\n",
        "print(\"✓ Figura comparativa geral exibida.\")\n",
        "\n",
        "# --- GRÁFICO 3: EVOLUÇÃO RELATIVA (NORMALIZAÇÃO BASE 100) ---\n",
        "plt.figure(figsize=(10, 6))\n",
        "todos_anos_list = set()\n",
        "\n",
        "for local, df in analises.items():\n",
        "    if df.empty: continue\n",
        "    todos_anos_list.update(df['ano'].unique())\n",
        "    pib_normalizado = (df['pibpc'] / df['pibpc'].iloc[0]) * 100\n",
        "    plt.plot(df['ano'], pib_normalizado, marker='o', linewidth=2, label=local)\n",
        "\n",
        "plt.xticks(sorted(list(todos_anos_list)), rotation=45)\n",
        "plt.axhline(100, color='gray', linestyle='--', linewidth=1)\n",
        "plt.title('Velocidade de Crescimento da Renda (Base 100 = Ano Inicial)', fontsize=13)\n",
        "plt.xlabel('Ano')\n",
        "plt.ylabel('Índice (100 = Início do Período)')\n",
        "plt.legend()\n",
        "plt.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig('evolucao_normalizada.png', dpi=150, bbox_inches='tight')\n",
        "plt.show() # <-- ADICIONADO AQUI\n",
        "plt.close()\n",
        "\n",
        "# --- DIAGNÓSTICO ESTATÍSTICO DOS MUNICÍPIOS ---\n",
        "print(\"\\n>>> DIAGNÓSTICO DOS 22 MUNICÍPIOS DA REGIÃO SUL\")\n",
        "cores = cm.tab20(range(22))\n",
        "municipios_alto_crescimento, municipios_crescimento_normal = [], []\n",
        "todos_anos_sul = set()\n",
        "\n",
        "for i, municipio in enumerate(MUNICIPIOS_SUL):\n",
        "    df_mun = df_completo[df_completo['municipio'] == municipio].sort_values('ano')\n",
        "    if df_mun.empty or len(df_mun) < 2 or df_mun['pibpc'].iloc[0] <= 0: continue\n",
        "\n",
        "    anos_mun = df_mun['ano'].values\n",
        "    todos_anos_sul.update(anos_mun)\n",
        "\n",
        "    variacao_total = ((df_mun['pibpc'].iloc[-1] - df_mun['pibpc'].iloc[0]) / df_mun['pibpc'].iloc[0]) * 100\n",
        "    pib_normalizado = (df_mun['pibpc'] / df_mun['pibpc'].iloc[0]) * 100\n",
        "\n",
        "    dados_plot = (municipio, anos_mun, pib_normalizado, cores[i], variacao_total)\n",
        "    if variacao_total > 350:\n",
        "        municipios_alto_crescimento.append(dados_plot)\n",
        "    else:\n",
        "        municipios_crescimento_normal.append(dados_plot)\n",
        "\n",
        "anos_unicos_sul = sorted(list(todos_anos_sul))\n",
        "\n",
        "# Figura a3: Típico\n",
        "fig_a3, ax1 = plt.subplots(figsize=(12, 7))\n",
        "for mun, anos_mun, pib_norm, cor, var in municipios_crescimento_normal:\n",
        "    estilos = {'linewidth': 3, 'color': 'red', 'zorder': 10} if mun == 'Rio Grande' else \\\n",
        "              {'linewidth': 2.5, 'color': 'blue', 'zorder': 9} if mun == 'Pelotas' else \\\n",
        "              {'linewidth': 1.8, 'color': cor, 'alpha': 0.8}\n",
        "    marker = 'o' if mun == 'Rio Grande' else 's' if mun == 'Pelotas' else '.'\n",
        "    ax1.plot(anos_mun, pib_norm, marker=marker, label=f\"{mun} ({var:.0f}%)\", **estilos)\n",
        "\n",
        "ax1.set(xticks=anos_unicos_sul, title='Crescimento \"Típico\" da Região\\n(Variação até 350%)', xlabel='Ano', ylabel='Índice (100 = 2010)')\n",
        "ax1.tick_params(axis='x', rotation=45)\n",
        "ax1.axhline(100, color='black', linestyle='--', linewidth=1.5, alpha=0.5)\n",
